# Modelo de secrets.toml — copiar para .streamlit/secrets.toml e preencher.
# O arquivo real NUNCA deve ser versionado (está no .gitignore).

app_password = "SENHA_DO_APP_AQUI"

# ID do arquivo da planilha (da URL do Google Sheets), nunca a URL completa
spreadsheet_id = "ID_DA_PLANILHA_AQUI"

# Ferramenta de validação de indicadores (somente desenvolvimento):
# habilita a página 🔧 Auditoria na navegação. Nunca ativar em produção.
# dev_auditoria = true

[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "nome@projeto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
